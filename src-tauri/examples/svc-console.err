[evorift-svc][audit] listening
[evorift-svc][audit] auto-start ok (boot koruması açık)
[evorift-svc][audit] exec powershell -NoProfile -Command $ErrorActionPreference='SilentlyContinue'; $dns=@('1.1.1.1','1.0.0.1') + @('2606:4700:4700::1111','2606:4700:4700::1001'); $tpl='https://cloudflare-dns.com/dns-query'; $ad=@(Get-NetAdapter -Physical); foreach($a in $ad){ Set-DnsClientServerAddress -InterfaceIndex $a.InterfaceIndex -ServerAddresses $dns -Confirm:$false }; $b=[System.Environment]::OSVersion.Version.Build; if($b -ge 22621){ foreach($ip in @('1.1.1.1','1.0.0.1')){ Add-DnsClientDohServerAddress -ServerAddress $ip -DohTemplate $tpl -AllowFallbackToUdp $false -AutoUpgrade $true -Confirm:$false } } else { foreach($ip in @('1.1.1.1','1.0.0.1')){ netsh dns add encryption server=$ip dohtemplate=$tpl autoupgrade=yes | Out-Null } }; Clear-DnsClientCache
